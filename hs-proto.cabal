                    , Proto.Bench
                    , Proto.Bench_Fields
    build-depends:
        base               >= 4.16 && < 5
      , hs-proto
      , bytestring
      , text
      , vector
      , deepseq
      , criterion          >= 1.5  && < 1.7
      , proto-lens         >= 0.7  && < 0.8
      , proto-lens-runtime >= 0.7  && < 0.8
      , lens-family        >= 2.1  && < 2.2

    hs-source-dirs:   compare-bench
                    , compare-bench/gen
    default-language: GHC2021
    default-extensions:
