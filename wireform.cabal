cabal-version:      3.0
name:               wireform
version:            0.1.0.0
synopsis:           High-performance multi-format serialization toolkit for Haskell
description:
  A comprehensive binary serialization library supporting 16 formats:
  .
  * Protocol Buffers (proto2/proto3 with full IDL parser, code generation, JSON mapping)
  * Apache Avro (schema resolution, JSON conversion, protocol/IPC)
  * Apache Thrift (binary protocol, schema, JSON)
  * CBOR (RFC 7049 values, encoding/decoding, JSON bridge)
  * MessagePack (values, encoding/decoding, JSON bridge)
  * BSON (MongoDB wire format)
  * Amazon Ion (binary Ion values)
  * Cap'n Proto (zero-copy serialization)
  * FlatBuffers (zero-copy flat serialization)
  * Microsoft Bond (compact binary)
  * ASN.1 BER/DER (ITU-T X.690)
  * Apache Parquet (columnar metadata/footer)
  * Apache Arrow IPC (in-memory columnar)
  * Apache Iceberg (table metadata/manifests)
  * Python Pickle (opcodes 0–5)
  * EDN (Extensible Data Notation)

license:            BSD-3-Clause
homepage:           https://github.com/iand675/wireform-
bug-reports:        https://github.com/iand675/wireform-/issues
build-type:         Simple
tested-with:        GHC == 9.6.4, GHC == 9.8.4
extra-source-files: CHANGELOG.md

data-files:
  proto/google/protobuf/any.proto
  proto/google/protobuf/api.proto
  proto/google/protobuf/duration.proto
  proto/google/protobuf/empty.proto
  proto/google/protobuf/field_mask.proto
  proto/google/protobuf/source_context.proto
  proto/google/protobuf/struct.proto
  proto/google/protobuf/timestamp.proto
  proto/google/protobuf/type.proto
  proto/google/protobuf/wrappers.proto

data-dir: .

source-repository head
  type:     git
  location: https://github.com/iand675/wireform-

flag python-interop
  description: Enable Python interop conformance tests (requires python3, protobuf pip package, protoc)
  manual: True
  default: False

common warnings
    ghc-options:
      -Wall
      -Wcompat
      -Widentities
      -Wincomplete-record-updates
      -Wincomplete-uni-patterns
      -Wpartial-fields
      -Wredundant-constraints
      -O2

