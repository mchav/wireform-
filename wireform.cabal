    , vector
    , deepseq
    , criterion          >= 1.5 && < 1.7
    , xml-conduit        >= 1.9 && < 1.11
    , xeno               >= 0.6 && < 0.7
    , hexml              >= 0.3 && < 0.5
  hs-source-dirs: bench
  ghc-options: -O2

benchmark quick-prof
  import: defaults
  type: exitcode-stdio-1.0
  main-is: QuickProf.hs
  build-depends:
      base >= 4.16 && < 5
    , wireform-proto
    , wireform-html
    , bytestring
    , text
    , deepseq
  hs-source-dirs: bench
  ghc-options: -O2 -rtsopts

benchmark html-bench
  import: defaults
  type: exitcode-stdio-1.0
  main-is: HTMLBench.hs
  build-depends:
      base >= 4.16 && < 5
    , wireform-core
    , wireform-html
    , bytestring
    , primitive
    , text
  hs-source-dirs: bench
  ghc-options: -rtsopts

executable profile-rewriter
  import: defaults
  main-is: ProfileRewriter.hs
  build-depends:
      base >= 4.16 && < 5
    , wireform-html
    , bytestring
    , text
  hs-source-dirs: bench
  ghc-options: -rtsopts
  -- The +profile flag re-enables cost-centre generation so
  -- @+RTS -p@ produces useful output. Build with
  --
  --   cabal build exe:profile-rewriter -fprofile --enable-profiling
  --
  -- Default-off so @cabal build all@ in CI stays green
  -- (--enable-profiling requires the entire dep closure to be
  -- built with profiling libs too).
  --
  -- 'ghc-options: -prof' would be wrong here: --enable-profiling
  -- already injects -prof for us, and adding it manually trips
  -- cabal-check's portability error. -fprof-late is the only
  -- knob we actually need on top.
  if flag(profile)
    ghc-options: -fprof-late

benchmark yaml-bench
  import: defaults
  type: exitcode-stdio-1.0
  main-is: YAMLBench.hs
  build-depends:
