      -- Convenience re-export modules
      Wireform.MsgPack
      Wireform.CBOR
      Wireform.Avro
      Wireform.Thrift
      Wireform.EDN
      Wireform.BSON
      Wireform.Ion
      Wireform.Bond
      Wireform.Proto
      Wireform.CapnProto
      Wireform.FlatBuffers
      Wireform.ASN1
      Wireform.Pickle
      -- XML support
      XML.Value
