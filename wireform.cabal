cabal-version:      3.0
name:               wireform
version:            0.1.0.0
synopsis:           High-performance multi-format serialization toolkit for Haskell
description:
  A comprehensive binary serialization library supporting 25+ formats.
  .
  This is the umbrella package.  It re-exports the public API of each
  format through @Wireform.*@ convenience modules and provides the
  @wireform-gen@ multi-format code-generation CLI.
  .
  Individual format packages (e.g. @wireform-proto@, @wireform-html@)
  can be depended on directly when you only need one format.

license:            BSD-3-Clause
license-file:       LICENSE
author:             Ian Duncan
maintainer:         ian@iankduncan.com
copyright:          2026 Ian Duncan
category:           Data, Codec, Serialization
homepage:           https://github.com/iand675/wireform-
bug-reports:        https://github.com/iand675/wireform-/issues
build-type:         Simple
tested-with:        GHC == 9.6.4, GHC == 9.8.4
extra-doc-files:
  CHANGELOG.md
  docs/README.md
  docs/getting-started.md

data-dir: .

source-repository head
  type:     git
  location: https://github.com/iand675/wireform-

flag python-interop
  description: Enable Python interop conformance tests (requires python3, protobuf pip package, protoc)
  manual: True
  default: False

flag profile
  description: Emit cost-centre annotations on the profile-rewriter
               binary (requires building the dep closure with
               --enable-profiling).
  manual: True
  default: False

flag dataframe-bridge
  description: Build the example-dataframe-bridge executable, which
               writes a Parquet file with wireform-parquet and reads
               it back through the dataframe library
               (https://hackage.haskell.org/package/dataframe). The
               dataframe dep tree is large (cassava, attoparsec,
               regex-tdfa, snappy-hs, zstd, zlib, granite,
               vector-algorithms, ...), so it is opt-in to keep the
               default `cabal build all` lean.
  manual: True
  default: False

common defaults
  ghc-options:
    -Wall
    -Wcompat
    -Widentities
    -Wincomplete-record-updates
    -Wincomplete-uni-patterns
    -Wpartial-fields
    -Wredundant-constraints
    -O2
  default-language: GHC2021
  default-extensions:
    StrictData
    DerivingStrategies
    DeriveGeneric
    DeriveAnyClass
    OverloadedStrings
    LambdaCase

-- Multi-format code generation CLI
executable wireform-gen
  import: defaults
  main-is: Main.hs
  hs-source-dirs: app
  build-depends:
      base                   >= 4.16 && < 5
    , wireform-proto
    , wireform-avro
    , wireform-thrift
    , wireform-bond
    , wireform-capnproto
    , wireform-flatbuffers
    , wireform-asn1
    , wireform-xml
    , text
    , containers
    , vector
    , directory
    , filepath
    , optparse-applicative   >= 0.17 && < 0.20

