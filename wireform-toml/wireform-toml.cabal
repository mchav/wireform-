cabal-version: 3.0
name: wireform-toml
version: 0.1.0.0
synopsis: TOML encoding/decoding
license: BSD-3-Clause
license-file: LICENSE
author: Ian Duncan
maintainer: ian@iankduncan.com
copyright: 2026 Ian Duncan
build-type: Simple

common defaults
  ghc-options:
    -Wall
    -Wcompat
    -Widentities
    -Wincomplete-record-updates
    -Wincomplete-uni-patterns
    -Wpartial-fields
    -Wredundant-constraints
    -O2
  default-language: GHC2021
  default-extensions:
    StrictData
    DerivingStrategies
    DeriveGeneric
    DeriveAnyClass
    OverloadedStrings
    LambdaCase

library
  import: defaults
  hs-source-dirs: src
  exposed-modules:
    TOML.Class
    TOML.Decode
    TOML.Derive
    TOML.Encode
    TOML.Encoding
    TOML.Value
  build-depends:
    base >= 4.16 && < 5,
    wireform-derive,
    bytestring >= 0.11 && < 0.13,
    text >= 2.0 && < 2.2,
    vector >= 0.13 && < 0.14,
    containers >= 0.6 && < 0.9,
    megaparsec >= 9.0 && < 10,
    time >= 1.9 && < 1.15,
    deepseq >= 1.4 && < 1.6,
    template-haskell >= 2.18 && < 2.24

benchmark wireform-toml-bench
  import: defaults
  type: exitcode-stdio-1.0
  hs-source-dirs: bench
  main-is: Bench.hs
  ghc-options: -O2
  build-depends:
    base,
    wireform-toml,
    deepseq,
    text,
    vector,
    criterion >= 1.5 && < 1.7

test-suite wireform-toml-derive-test
  import: defaults
  type: exitcode-stdio-1.0
  hs-source-dirs: test
  main-is: Main.hs
  other-modules:
    Test.TOML.Conformance
    Test.TOML.Derive
    Test.TOML.Derive.Types
    Test.TOML.Derive.Instances
  default-extensions:
    ScopedTypeVariables
    TemplateHaskell
  build-depends:
    base,
    wireform-toml,
    wireform-derive,
    aeson >= 2.1 && < 2.3,
    bytestring,
    text,
    vector,
    directory,
    filepath,
    tasty,
    tasty-hunit
