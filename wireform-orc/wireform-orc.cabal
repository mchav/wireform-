cabal-version: 3.0
name: wireform-orc
version: 0.1.0.0
synopsis: Apache ORC metadata, stripes, and read/write
license: BSD-3-Clause
build-type: Simple

common defaults
  ghc-options:
    -Wall
    -Wcompat
    -Widentities
    -Wincomplete-record-updates
    -Wincomplete-uni-patterns
    -Wpartial-fields
    -Wredundant-constraints
    -O2
  default-language: GHC2021
  default-extensions:
    StrictData
    DerivingStrategies
    DeriveGeneric
    DeriveAnyClass
    OverloadedStrings
    LambdaCase

library
  import: defaults
  hs-source-dirs: src
  exposed-modules:
    ORC.Footer
    ORC.Read
    ORC.Stripe
    ORC.Types
    ORC.Write
  other-modules:
    ORC.RLE
  build-depends:
    base >= 4.16 && < 5,
    wireform-core,
    bytestring >= 0.11 && < 0.13,
    text >= 2.0 && < 2.2,
    vector >= 0.13 && < 0.14,
    containers >= 0.6 && < 0.8,
    zlib >= 0.6 && < 0.8,
    deepseq >= 1.4 && < 1.6
