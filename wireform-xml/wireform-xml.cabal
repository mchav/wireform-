cabal-version: 3.0
name: wireform-xml
version: 0.1.0.0
synopsis: High-performance XML SAX/DOM parser, serializer, XPath, XSLT, and code generation
license: BSD-3-Clause
license-file: LICENSE
author: Ian Duncan
maintainer: ian@iankduncan.com
copyright: 2026 Ian Duncan
build-type: Simple

common defaults
  ghc-options:
    -Wall
    -Wcompat
    -Widentities
    -Wincomplete-record-updates
    -Wincomplete-uni-patterns
    -Wpartial-fields
    -Wredundant-constraints
    -O2
  default-language: GHC2021
  default-extensions:
    StrictData
    DerivingStrategies
    DeriveGeneric
    DeriveAnyClass
    OverloadedStrings
    LambdaCase

library
  import: defaults
  hs-source-dirs: src
  c-sources: cbits/fast_xml.c
  include-dirs: cbits
  cc-options: -O3 -march=native
  exposed-modules:
    XML.Class
    XML.CodeGen
    XML.DSL
    XML.Decode
    XML.Derive
    XML.Encode
    XML.Encoding
    XML.FastDOM
    XML.Generic
    XML.Incremental
    XML.Path
    XML.QQ
    XML.SAX
    XML.Schema
    XML.Value
    XML.XSLT
  build-depends:
    base >= 4.16 && < 5,
    wireform-core,
    wireform-derive,
    bytestring >= 0.11 && < 0.13,
    text >= 2.0 && < 2.2,
    vector >= 0.13 && < 0.14,
    primitive >= 0.7 && < 0.10,
    containers >= 0.6 && < 0.9,
    megaparsec >= 9.0 && < 10,
    template-haskell >= 2.18 && < 2.24,
    prettyprinter >= 1.7 && < 1.8,
    aeson >= 2.1 && < 2.3,
    scientific >= 0.3 && < 0.4,
    hashable >= 1.3 && < 1.6,
    unordered-containers >= 0.2.16 && < 0.3,
    stm >= 2.5 && < 2.6,
    deepseq >= 1.4 && < 1.6

test-suite wireform-xml-derive-test
  import: defaults
  type: exitcode-stdio-1.0
  hs-source-dirs: test
  main-is: Main.hs
  other-modules:
    Test.XML.Derive
    Test.XML.Derive.Types
    Test.XML.Derive.Instances
  default-extensions:
    ScopedTypeVariables
    TemplateHaskell
  build-depends:
    base,
    wireform-xml,
    wireform-derive,
    text,
    vector,
    sydtest
