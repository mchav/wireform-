# Stray criterion HTML reports from `cabal run wireform-fory:bench:... -- --output …`
# accidentally interpreted as a shell glob.
f-string
*-report.html
.cabal-sandbox/
cabal.sandbox.config
*.o
*.hi
*.dyn_o
*.dyn_hi
.ghc.environment.*
cabal.project.local
cabal.project.local.*
cabal.project.local~
__pycache__/
*.pyc
.direnv/
result
result-*

# Stray criterion output written to the repo root. Keep these
# scoped to the top level so test/fixture .csv / .html files in
# subdirectories aren't ignored by accident. If you actually want
# to commit benchmark output, put it under bench/ or docs/.
/*.csv
/*.tsv
/bench-*.html
/bench-*.json
# Scratch files created by the upstream conformance_test_runner.
nonexistent_tests.txt
failing_tests.txt
**/nonexistent_tests.txt
**/failing_tests.txt

wireform-yaml-bench.prof

# bench artefacts: per-run html/json/csv reports stay local.
benchmark/results/
wireform-kafka/benchmark/results/
